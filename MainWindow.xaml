<Window x:Class="MHRebornLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Marvel Heroes Reborn Launcher"
        Width="1180" Height="760" MinWidth="980" MinHeight="650"
        WindowStartupLocation="CenterScreen" Background="#0D1017"
        WindowStyle="None" ResizeMode="CanResize"
        StateChanged="Window_StateChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="7"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="LauncherContentScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="7"/>
            <Setter Property="MinWidth" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="3,3,3,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="38">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Background="#626B7B" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryPlayButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#148BEB"/>
            <Setter Property="BorderBrush" Value="#148BEB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#249AF4"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#249AF4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#0F78CC"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#0F78CC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#E8EEF7"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Setter Property="Opacity" Value="1"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#303744"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#465064"/>
                            </Trigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEnabled, RelativeSource={RelativeSource Self}}" Value="False"/>
                                    <Condition Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="GAME RUNNING"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#1B6FAF"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#2C8ED6"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="62"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#12161E" BorderBrush="#303642" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="OptionsButton" Content="OPTIONS" Click="OptionsButton_Click"
                            Background="Transparent" BorderBrush="#3A4352" BorderThickness="1"
                            Padding="12,6" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="LauncherVersionText" Margin="12,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse x:Name="ServerStatusDot" Width="9" Height="9" Margin="0,0,8,0" Fill="#788397"/>
                    <TextBlock x:Name="ServerStatusText" Text="Checking server..." FontSize="12" FontWeight="SemiBold" Foreground="#C7CFDC" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0">
                    <Button x:Name="AccountButton" Background="Transparent" Padding="10,7" Click="AccountButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="RankBadgeBorder" CornerRadius="4" Padding="8,4" Background="#285B91" VerticalAlignment="Center">
                                <TextBlock x:Name="RankBadgeText" Text="USER" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="PlayerNameText" FontSize="15" FontWeight="SemiBold" Margin="10,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="⌄" FontSize="16" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="AccountPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=AccountButton}" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="#202530" BorderBrush="#414959" BorderThickness="1" CornerRadius="5" Padding="6" Width="210">
                            <StackPanel>
                                <Button Content="ACCOUNT PORTAL" Background="Transparent" HorizontalContentAlignment="Left" Click="AccountPortalButton_Click"/>
                                <Button Content="SIGN OUT" Background="Transparent" HorizontalContentAlignment="Left" Foreground="#D9DEE8" Click="SignOutButton_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-1,-22,0">
                    <Button x:Name="MinimizeWindowButton" Content="—" Width="46" Height="32" Padding="0" FontSize="14"
                            Background="Transparent" BorderThickness="0" Click="MinimizeWindowButton_Click"/>
                    <Button x:Name="MaximizeWindowButton" Content="□" Width="46" Height="32" Padding="0" FontSize="14"
                            Background="Transparent" BorderThickness="0" Click="MaximizeWindowButton_Click"/>
                    <Button Content="✕" Width="46" Height="32" Padding="0" FontSize="13"
                            Background="Transparent" BorderThickness="0" Click="CloseWindowButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22">
            <Grid.ColumnDefinitions><ColumnDefinition Width="245"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#171B23" CornerRadius="6" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel HorizontalAlignment="Stretch">
                        <Image Source="pack://application:,,,/MHRebornLauncher;component/Assets/OmegaNodeLogo.png" Width="145" Height="135" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock Text="MARVEL HEROES" FontSize="21" FontWeight="Bold" Margin="0,8,0,0" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text="REBORN" FontSize="13" FontWeight="SemiBold" Foreground="#C9D1E0" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Height="1" Background="#303642" Margin="0,16,0,14"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="LIVE EVENTS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="#222936" CornerRadius="8" Padding="7,2" Margin="8,0,0,0">
                                <TextBlock x:Name="EventsUpdatedText" FontSize="9" FontWeight="SemiBold" Foreground="#9BA7BA" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,9,0,10">
                            <StackPanel x:Name="ActiveEventsPanel">
                                <TextBlock Text="Checking active events..." Foreground="#8A95A8" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <StackPanel Grid.Row="3" Margin="0,8,0,16">
                        <TextBlock Text="GAME STATUS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                            <Ellipse x:Name="GameFoundDot" Width="9" Height="9" Margin="0,0,8,0"/>
                            <TextBlock x:Name="GameFoundText" FontSize="12" Foreground="#C7CFDC" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="GamePlacementText" TextWrapping="Wrap" FontSize="10" Foreground="#8A95A8" Margin="0,9,0,0" LineHeight="15" Visibility="Collapsed"/>
                    </StackPanel>

                    <Button Grid.Row="4" x:Name="PlayButton" Content="PLAY" Height="54" FontSize="18" Style="{StaticResource PrimaryPlayButtonStyle}" Click="PlayButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="NoticeBanner" Visibility="Collapsed" Background="#1C2633" BorderBrush="#38BDF8" BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="NoticeTitleText" FontWeight="Bold" FontSize="12"/>
                            <TextBlock x:Name="NoticeMessageText" Foreground="#C7CFDC" FontSize="11" TextWrapping="Wrap" Margin="0,3,12,0"/>
                        </StackPanel>
                        <Button x:Name="NoticeActionButton" Grid.Column="1" Content="VIEW" Width="74" Height="30" Visibility="Collapsed" Click="NoticeActionButton_Click"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="NewsTabButton" Content="NEWS" Width="112" Height="34" Click="NewsTabButton_Click"/>
                    <Button x:Name="GoalsTabButton" Content="COMMUNITY GOAL" Width="160" Height="34" Margin="8,0,0,0" Background="#303744" Click="GoalsTabButton_Click"/>
                    <Button x:Name="AccountTabButton" Content="ACCOUNT" Width="112" Height="34" Margin="8,0,0,0" Background="#303744" Click="AccountTabButton_Click"/>
                </StackPanel>

                <Border Grid.Row="2" Background="#181C25" CornerRadius="6" ClipToBounds="True">
                    <Grid>
                        <Grid x:Name="NewsPanel" Margin="34">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="FeaturedCategoryText" Text="NEWS" FontSize="11" FontWeight="Bold" Foreground="#9FA9BA"/>
                                <TextBlock x:Name="FeaturedDateText" FontSize="11" Foreground="#788397" Margin="0,5,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Row="1" x:Name="FeaturedTitleText" FontSize="30" FontWeight="Bold" TextWrapping="Wrap" Margin="0,16,0,16"/>
                            <Border Grid.Row="2" Background="Transparent" ClipToBounds="True">
                                <wv2:WebView2 x:Name="NewsWebView"/>
                            </Border>
                            <Grid Grid.Row="3" Margin="0,20,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <Button Content="READ MORE" Width="150" Height="42" HorizontalAlignment="Left" Click="ReadMoreButton_Click"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="‹" Width="38" Height="34" Background="#353C49" ToolTip="Previous article" Click="PreviousNewsButton_Click"/>
                                    <TextBlock x:Name="NewsPositionText" Margin="12,0" VerticalAlignment="Center" Foreground="#9FA9BA" FontSize="11"/>
                                    <Button Content="›" Width="38" Height="34" Background="#353C49" ToolTip="Next article" Click="NextNewsButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <ScrollViewer x:Name="GoalsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.Resources>
                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource LauncherContentScrollBarStyle}"/>
                            </ScrollViewer.Resources>
                            <StackPanel Margin="32,26,32,28">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="COMMUNITY GOAL" Foreground="#22D3EE" FontWeight="Bold" FontSize="11"/>
                                        <TextBlock x:Name="GoalTitleText" Text="Loading community goal..." FontSize="30" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#153C32" CornerRadius="12" Padding="10,5" VerticalAlignment="Top">
                                        <TextBlock Text="ACTIVE" Foreground="#75E6AD" FontWeight="Bold" FontSize="10"/>
                                    </Border>
                                </Grid>
                                <TextBlock x:Name="GoalDescriptionText" Foreground="#C7CFDC" TextWrapping="Wrap" Margin="0,10,0,16"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="GoalProgressText" FontWeight="Bold"/>
                                    <TextBlock x:Name="GoalPercentText" Grid.Column="1" FontWeight="Bold"/>
                                </Grid>
                                <Grid Height="12" Margin="0,0,0,14">
                                    <Border Background="#2A303C" CornerRadius="6"/>
                                    <ProgressBar x:Name="GoalProgressBar" Minimum="0" Maximum="100" Height="12" BorderThickness="0"/>
                                </Grid>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Background="#11161E" CornerRadius="6" Padding="13" Margin="0,0,6,0">
                                        <StackPanel><TextBlock Text="ENDS" Foreground="#8FA0B7" FontSize="9" FontWeight="Bold"/><TextBlock x:Name="GoalEndsText" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#11161E" CornerRadius="6" Padding="13" Margin="6,0,0,0">
                                        <StackPanel><TextBlock Text="YOUR CONTRIBUTION" Foreground="#8FA0B7" FontSize="9" FontWeight="Bold"/><TextBlock x:Name="GoalPlayerContributionText" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Text="Community Rewards" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                <WrapPanel x:Name="CommunityRewardsPanel" Margin="0,0,0,18"/>

                                <TextBlock Text="Contributor Rewards" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                <WrapPanel x:Name="RankRewardsPanel" Margin="0,0,0,18"/>

                                <TextBlock Text="Top Contributors" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                <StackPanel x:Name="ContributorsPanel"/>

                                <Button Content="VIEW FULL COMMUNITY GOALS" Height="40" Width="230" HorizontalAlignment="Left" Margin="0,20,0,0" Click="OpenCommunityGoalsButton_Click"/>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="AccountPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.Resources>
                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource LauncherContentScrollBarStyle}"/>
                            </ScrollViewer.Resources>
                            <StackPanel Margin="32,26,32,28">
                                <TextBlock Text="PLAYER ACCOUNT" Foreground="#38BDF8" FontWeight="Bold" FontSize="11"/>
                                <TextBlock Text="Account &amp; Progression" FontSize="30" FontWeight="Bold" Margin="0,8,0,18"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Background="#11161E" CornerRadius="6" Padding="16" Margin="0,0,7,0">
                                        <StackPanel>
                                            <TextBlock Text="ACCOUNT" Foreground="#8FA0B7" FontSize="9" FontWeight="Bold"/>
                                            <TextBlock x:Name="AccountPlayerNameText" FontSize="20" FontWeight="Bold" Margin="0,5,0,0"/>
                                            <TextBlock x:Name="AccountEmailText" Foreground="#AAB4C5" Margin="0,3,0,0"/>
                                            <TextBlock x:Name="AccountRankStatusText" Foreground="#75E6AD" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#11161E" CornerRadius="6" Padding="16" Margin="7,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="SECURITY" Foreground="#8FA0B7" FontSize="9" FontWeight="Bold"/>
                                            <TextBlock x:Name="AccountTwoFactorText" FontWeight="SemiBold" Margin="0,7,0,0"/>
                                            <TextBlock x:Name="AccountRecoveryText" FontWeight="SemiBold" Margin="0,7,0,0"/>
                                            <Button Content="OPEN SECURITY SETTINGS" Height="34" Padding="14,0" HorizontalAlignment="Left" Margin="0,12,0,0" Click="OpenAccountPortalButton_Click"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Text="Community Goal Rewards" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                <StackPanel x:Name="AccountRewardClaimsPanel" Margin="0,0,0,18"/>

                                <TextBlock Text="Recent Community Goals" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                                <StackPanel x:Name="AccountGoalHistoryPanel"/>

                                <Border x:Name="PreviewModeBorder" Visibility="Collapsed" Background="#201A2B" BorderBrush="#A855F7" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,20,0,0">
                                    <StackPanel>
                                        <TextBlock Text="ADMIN DASHBOARD PREVIEW" Foreground="#C084FC" FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Text="Preview reward and security states without changing live events or database records." Foreground="#C7CFDC" TextWrapping="Wrap" Margin="0,5,0,9"/>
                                        <ComboBox x:Name="DashboardPreviewCombo" Width="260" HorizontalAlignment="Left" SelectionChanged="DashboardPreviewCombo_SelectionChanged">
                                            <ComboBoxItem Content="Live Data" Tag="live" IsSelected="True"/>
                                            <ComboBoxItem Content="Rank 1 Reward Pending" Tag="pending-rank-1"/>
                                            <ComboBoxItem Content="Ranks 2–3 Reward Pending" Tag="pending-rank-2"/>
                                            <ComboBoxItem Content="Ranks 4–10 Reward Pending" Tag="pending-rank-4"/>
                                            <ComboBoxItem Content="Reward Delivered" Tag="delivered"/>
                                            <ComboBoxItem Content="2FA Disabled" Tag="security-incomplete"/>
                                            <ComboBoxItem Content="Fully Secured Account" Tag="security-complete"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <DockPanel Grid.Row="3" Margin="0,16,0,0" LastChildFill="False">
                    <TextBlock x:Name="NewsStatusText" Text="Loading news..." Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <Button x:Name="RefreshContentButton" Content="REFRESH NEWS" Height="38" Padding="18,0" Margin="16,0,0,0" HorizontalAlignment="Right" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" DockPanel.Dock="Right" Background="#303744" Click="RefreshContentButton_Click"/>
                </DockPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#11151C" BorderBrush="#303642" BorderThickness="0,1,0,0">
            <TextBlock x:Name="FooterText" Text="Ready" VerticalAlignment="Center" Margin="22,0" Foreground="#808A9C" FontSize="11"/>
        </Border>
    </Grid>
</Window>
