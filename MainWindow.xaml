<Window x:Class="MHRebornLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Marvel Heroes Reborn Launcher"
        Width="1180" Height="760" MinWidth="980" MinHeight="650"
        WindowStartupLocation="CenterScreen" Background="#0D1017">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="62"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#12161E" BorderBrush="#303642" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="OptionsButton" Content="OPTIONS" Click="OptionsButton_Click"
                            Background="Transparent" BorderBrush="#3A4352" BorderThickness="1"
                            Padding="12,6" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock x:Name="LauncherVersionText" Margin="12,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse x:Name="ServerStatusDot" Width="9" Height="9" Margin="0,0,8,0" Fill="#788397"/>
                    <TextBlock x:Name="ServerStatusText" Text="Checking server..." FontSize="12" FontWeight="SemiBold" Foreground="#C7CFDC" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Button x:Name="AccountButton" Background="Transparent" Padding="10,7" Click="AccountButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="RankBadgeBorder" CornerRadius="4" Padding="8,4" Background="#285B91" VerticalAlignment="Center">
                                <TextBlock x:Name="RankBadgeText" Text="USER" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="PlayerNameText" FontSize="15" FontWeight="SemiBold" Margin="10,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="⌄" FontSize="16" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Popup x:Name="AccountPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=AccountButton}" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="#202530" BorderBrush="#414959" BorderThickness="1" CornerRadius="5" Padding="6" Width="210">
                            <StackPanel>
                                <Button Content="ACCOUNT PORTAL" Background="Transparent" HorizontalContentAlignment="Left" Click="AccountPortalButton_Click"/>
                                <Button Content="SIGN OUT" Background="Transparent" HorizontalContentAlignment="Left" Foreground="#D9DEE8" Click="SignOutButton_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22">
            <Grid.ColumnDefinitions><ColumnDefinition Width="245"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#171B23" CornerRadius="6" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel HorizontalAlignment="Stretch">
                        <Image Source="pack://application:,,,/MHRebornLauncher;component/Assets/OmegaNodeLogo.png" Width="145" Height="135" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock Text="MARVEL HEROES" FontSize="21" FontWeight="Bold" Margin="0,8,0,0" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text="REBORN" FontSize="13" FontWeight="SemiBold" Foreground="#C9D1E0" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Height="1" Background="#303642" Margin="0,16,0,14"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="LIVE EVENTS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Background="#222936" CornerRadius="8" Padding="7,2" Margin="8,0,0,0">
                                <TextBlock x:Name="EventsUpdatedText" FontSize="9" FontWeight="SemiBold" Foreground="#9BA7BA" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,9,0,10">
                            <StackPanel x:Name="ActiveEventsPanel">
                                <TextBlock Text="Checking active events..." Foreground="#8A95A8" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <StackPanel Grid.Row="3" Margin="0,8,0,16">
                        <TextBlock Text="GAME STATUS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,9,0,0">
                            <Ellipse x:Name="GameFoundDot" Width="9" Height="9" Margin="0,0,8,0"/>
                            <TextBlock x:Name="GameFoundText" FontSize="12" Foreground="#C7CFDC" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="GamePlacementText" TextWrapping="Wrap" FontSize="10" Foreground="#8A95A8" Margin="0,9,0,0" LineHeight="15" Visibility="Collapsed"/>
                    </StackPanel>

                    <Button Grid.Row="4" x:Name="PlayButton" Content="PLAY" Height="54" FontSize="18" Click="PlayButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Border Background="#181C25" CornerRadius="6" ClipToBounds="True">
                    <Grid Margin="34">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="FeaturedCategoryText" Text="NEWS" FontSize="11" FontWeight="Bold" Foreground="#9FA9BA"/>
                            <TextBlock x:Name="FeaturedDateText" FontSize="11" Foreground="#788397" Margin="0,5,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" x:Name="FeaturedTitleText" FontSize="30" FontWeight="Bold" TextWrapping="Wrap" Margin="0,16,0,16"/>
                        <Border Grid.Row="2" Background="Transparent" ClipToBounds="True">
                            <wv2:WebView2 x:Name="NewsWebView"/>
                        </Border>
                        <Grid Grid.Row="3" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Button Content="READ MORE" Width="150" Height="42" HorizontalAlignment="Left" Click="ReadMoreButton_Click"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="‹" Width="38" Height="34" Background="#353C49" ToolTip="Previous article" Click="PreviousNewsButton_Click"/>
                                <TextBlock x:Name="NewsPositionText" Margin="12,0" VerticalAlignment="Center" Foreground="#9FA9BA" FontSize="11"/>
                                <Button Content="›" Width="38" Height="34" Background="#353C49" ToolTip="Next article" Click="NextNewsButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                <DockPanel Grid.Row="1" Margin="0,16,0,0">
                    <TextBlock x:Name="NewsStatusText" Text="Loading news..." Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <Button Content="REFRESH NEWS" Width="130" Height="36" DockPanel.Dock="Right" Background="#303744" Click="RefreshNewsButton_Click"/>
                </DockPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#11151C" BorderBrush="#303642" BorderThickness="0,1,0,0">
            <TextBlock x:Name="FooterText" Text="Ready" VerticalAlignment="Center" Margin="22,0" Foreground="#808A9C" FontSize="11"/>
        </Border>
    </Grid>
</Window>
