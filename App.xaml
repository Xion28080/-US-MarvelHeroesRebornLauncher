<Application x:Class="MHRebornLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#0D1017"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#181C25"/>
        <SolidColorBrush x:Key="CardBrush" Color="#222733"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#148BEB"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F4F7FB"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#AEB6C6"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#343B49"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF6969"/>

        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource TextBrush}"/></Style>
        <Style TargetType="Window"><Setter Property="FontFamily" Value="Segoe UI"/><Setter Property="Background" Value="{StaticResource BgBrush}"/><Setter Property="Foreground" Value="{StaticResource TextBrush}"/></Style>
        <Style TargetType="TextBox"><Setter Property="Background" Value="#151A23"/><Setter Property="Foreground" Value="#F4F7FB"/><Setter Property="BorderBrush" Value="#4A5262"/><Setter Property="CaretBrush" Value="#F4F7FB"/><Setter Property="Padding" Value="11,7"/></Style>
        <Style TargetType="PasswordBox"><Setter Property="Background" Value="#151A23"/><Setter Property="Foreground" Value="#F4F7FB"/><Setter Property="BorderBrush" Value="#4A5262"/><Setter Property="CaretBrush" Value="#F4F7FB"/><Setter Property="Padding" Value="11,7"/></Style>
        <Style TargetType="Button"><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="{StaticResource AccentBrush}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Padding" Value="14,8"/></Style>
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="{StaticResource TextBrush}"/></Style>
    </Application.Resources>
</Application>
