<Application x:Class="MHRebornLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BgBrush" Color="#080D16"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#151F33"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1E2B46"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#F5B83D"/>
        <SolidColorBrush x:Key="TextBrush" Color="#F4F7FF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B8C5DD"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#30415F"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF6B6B"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="{StaticResource BgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#10182A"/>
            <Setter Property="Foreground" Value="#F4F7FF"/>
            <Setter Property="BorderBrush" Value="#3D4F70"/>
            <Setter Property="CaretBrush" Value="#F4F7FF"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#10182A"/>
            <Setter Property="Foreground" Value="#F4F7FF"/>
            <Setter Property="BorderBrush" Value="#3D4F70"/>
            <Setter Property="CaretBrush" Value="#F4F7FF"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#05070D"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
    </Application.Resources>
</Application>
