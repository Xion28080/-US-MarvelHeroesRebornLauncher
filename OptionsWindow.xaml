<Window x:Class="MHRebornLauncher.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Launcher Options"
        Width="720" Height="500" MinWidth="660" MinHeight="440"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="#0D1017" ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#12161E" BorderBrush="#303642" BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <TextBlock Text="OPTIONS" FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Width="34" Height="34"
                        Padding="0" Background="Transparent" Foreground="#AEB6C6" Click="CloseButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="185"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#141820" BorderBrush="#303642" BorderThickness="0,0,1,0" Padding="14,18">
                <StackPanel>
                    <Button Content="GENERAL" HorizontalContentAlignment="Left" Background="#243142"
                            BorderBrush="#148BEB" BorderThickness="3,0,0,0" Padding="16,12"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="28,24,30,26">
                    <TextBlock Text="General" FontSize="25" FontWeight="Bold"/>
                    <TextBlock Text="Choose how Marvel Heroes starts when you click Play."
                               Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,22"/>

                    <Border Background="#181C25" BorderBrush="#343B49" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Hide the startup splash" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Hides the small startup window shown before the game opens."
                                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="SkipLaunchSplashCheckBox" Grid.Column="1" VerticalAlignment="Center"
                                      Width="20" Height="20"/>
                        </Grid>
                    </Border>

                    <Border Background="#181C25" BorderBrush="#343B49" BorderThickness="1" CornerRadius="6" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Skip intro videos" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Skips the opening videos so clicking Play takes you directly into the game."
                                           Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="SkipStartupMoviesCheckBox" Grid.Column="1" VerticalAlignment="Center"
                                      Width="20" Height="20"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Background="#12161E" BorderBrush="#303642" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,22,0">
                <Button Content="CANCEL" Width="105" Margin="0,0,10,0" Background="#2A303C" Click="CancelButton_Click"/>
                <Button Content="SAVE" Width="105" Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
